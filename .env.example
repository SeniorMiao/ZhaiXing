APP_ENV=dev

# 本机 MySQL/Redis 默认装在 D:\01_Dev\Environment（见 scripts\setup-deps.ps1）
DATABASE_URL=mysql+pymysql://zx:zxpass@127.0.0.1:3306/meeting_assistant?charset=utf8mb4
REDIS_URL=redis://127.0.0.1:6379/0

# JWT（生产环境务必改为足够长的随机字符串）
JWT_SECRET_KEY=dev-only-change-me

# 国内建议：
HF_ENDPOINT=https://hf-mirror.com

# ASR 模型：tiny / base / small / medium / large-v3 ...
ASR_MODEL=medium
# auto=自动检测；zh/en 等=强制语言
ASR_LANGUAGE=auto
# 长音频分段转写（秒），防 OOM，默认 300
ASR_CHUNK_SECONDS=300
# ASR_INITIAL_PROMPT=

# 智谱摘要（留空则使用本地 fallback 摘录，非 AI 归纳；申请：https://open.bigmodel.cn/）
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash

# 说话人分离（3D-Speaker CAM++，ModelScope，无需 HuggingFace）
DIARIZATION_ENABLED=true
# DIARIZATION_MODEL_CACHE=D:/01_Dev/Environment/ModelScopeCache
# DIARIZATION_SPEAKER_NUM=2

# 旧方案（pyannote，需 HF Token，当前未使用）
HF_TOKEN=

