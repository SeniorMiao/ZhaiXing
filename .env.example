APP_ENV=dev

DATABASE_URL=mysql+pymysql://zx:zxpass@127.0.0.1:3306/meeting_assistant?charset=utf8mb4
REDIS_URL=redis://127.0.0.1:6379/0

# JWT（生产环境务必改为足够长的随机字符串）
JWT_SECRET_KEY=dev-only-change-me

# 国内建议：
HF_ENDPOINT=https://hf-mirror.com

# ASR 模型：tiny / base / small / medium / large-v3 ...
ASR_MODEL=medium

# 智谱摘要
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-5.1

# 说话人分离（可选：pyannote 需要 HuggingFace token + 额外重依赖）
HF_TOKEN=

